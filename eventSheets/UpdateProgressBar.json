		{
			"functionName": "AddProgress",
			"functionDescription": "",
			"functionCategory": "",
			"functionReturnType": "none",
			"functionCopyPicked": false,
			"functionIsAsync": false,
			"functionParameters": [
				{
					"name": "value",
					"type": "number",
					"initialValue": "0",
					"comment": "",
					"sid": 549860802891246
				},
				{
					"name": "category",
					"type": "string",
					"initialValue": "",
					"comment": "",
					"sid": 561378413148736
				}
			],
			"eventType": "function-block",
			"conditions": [],
			"actions": [
				{
					"type": "script",
					"language": "javascript",
					"script": [
						"// ===============================",
						"// Add Progress",
						"// ===============================",
						"",
						"const value = localVars.value;",
						"const category = localVars.category;",
						"",
						"// Cari progress bar berdasarkan kategori",
						"const bar = runtime.objects.ProgressFill",
						"    .getAllInstances()",
						"    .find(p => p.instVars.category === category);",
						"",
						"if (!bar) {",
						"    console.log(\"ProgressFill tidak ditemukan:\", category);",
						"    return;",
						"}",
						"",
						"// Tambah progress",
						"bar.instVars.Current = Math.min(",
						"    bar.instVars.Current + value,",
						"    bar.instVars.Max",
						");",
						"",
						"// Update ukuran progress bar",
						"bar.width =",
						"    (bar.instVars.Current / bar.instVars.Max) *",
						"    bar.instVars.BarWidth;",
						"",
						"// Debug",
						"console.log(",
						"    category,",
						"    \"Current:\",",
						"    bar.instVars.Current,",
						"    \"Max:\",",
						"    bar.instVars.Max,",
						"    \"Reward:\",",
						"    bar.instVars.rewardGiven",
						");",
						"",
						"// Jika progress penuh",
						"if (",
						"    bar.instVars.Current >= bar.instVars.Max &&",
						"    !bar.instVars.rewardGiven",
						") {",
						"    runtime.globalVars.koin += 10;",
						"",
						"    bar.instVars.rewardGiven = true;",
						"",
						"    console.log(",
						"        \"KOIN +10\",",
						"        \"Koin Saat Ini:\",",
						"        runtime.globalVars.koin,",
						"        \"Total Tersimpan:\",",
						"        runtime.globalVars.totalKoin",
						"    );",
						"}",
						"",
						"// Update bintang",
						"runtime.callFunction(\"Updatestar\");"
					]
				}
			],
			"sid": 303310230945250
		},
		{
			"functionName": "RemoveProgress",
