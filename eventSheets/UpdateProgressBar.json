				}
			],
			"eventType": "function-block",
			"conditions": [],
			"actions": [
				{
					"type": "script",
					"language": "javascript",
					"script": [
						"const value = localVars.value",
						"const category = localVars.category",
						"",
						"const bar = runtime.objects.ProgressFill",
						"\t.getAllInstances()",
						"\t.find(p => p.instVars.category === category)",
						"",
						"if (!bar) return",
						"",
						"bar.instVars.Current = Math.max(",
						"\tbar.instVars.Current - value,",
						"\tbar.instVars.Min",
						")",
						"",
						"bar.width = ",
						"\t(bar.instVars.Current / bar.instVars.Max) *",
						"\tbar.instVars.BarWidth"
					]
				}
			],
			"sid": 389068017538995
		},
		{
			"functionName": "restrartKoin",
			"functionDescription": "",
			"functionCategory": "",
			"functionReturnType": "none",
			"functionCopyPicked": false,
			"functionIsAsync": false,
			"functionParameters": [],
			"eventType": "function-block",
			"conditions": [],
			"actions": [
				{
					"type": "script",
					"language": "javascript",
					"script": [
						"// ======================================",
						"// SIMPAN KOIN GAME KE TOTAL",
						"// ======================================",
						"",
						"runtime.globalVars.totalKoin += runtime.globalVars.koin;",
						"",
						"console.log(\"==================================\");",
						"console.log(\"RETRY\");",
						"console.log(\"Koin Game      :\", runtime.globalVars.koin);",
						"console.log(\"Total Koin     :\", runtime.globalVars.totalKoin);",
						"console.log(\"==================================\");",
						"",
						"// ======================================",
						"// RESET KOIN",
						"// ======================================",
						"",
						"runtime.globalVars.koin = 0;",
						"",
						"// Update Text Koin",
						"const txtKoin = runtime.objects.txtKoin.getFirstInstance();",
						"",
						"if (txtKoin) {",
						"    txtKoin.text = \"0\";",
						"}",
						"",
						"// ======================================",
						"// RESET SEMUA PROGRESS BAR",
						"// ======================================",
						"",
						"const bars = runtime.objects.ProgressFill.getAllInstances();",
						"",
						"for (const bar of bars)",
						"{",
						"    bar.instVars.Current = 0;",
						"    bar.instVars.rewardGiven = false;",
						"",
						"    bar.width =",
						"        (bar.instVars.Current / bar.instVars.Max) *",
						"        bar.instVars.BarWidth;",
						"}",
						"",
						"// ======================================",
						"// RESET STAR",
						"// ======================================",
						"",
						"runtime.globalVars.star_System = 0;",
						"",
						"console.log(\"Koin setelah reset :\", runtime.globalVars.koin);",
						"console.log(\"Semua Progress berhasil direset\");"
					]
				}
			],
			"sid": 664801439064239
		}
	],
